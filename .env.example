# Backend (Django)
SECRET_KEY=replace_me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Clerk — JWT issuer from Clerk Dashboard → API Keys (Frontend API URL)
# Example: https://your-app.clerk.accounts.dev
CLERK_ISSUER=

# Frontend (Vite) — publishable key from Clerk Dashboard → API Keys
VITE_CLERK_PUBLISHABLE_KEY=

# Optional — only when the frontend cannot use the Vite proxy or same-origin /api
# (e.g. frontend on a different machine). For ./start.sh, leave this unset.
# VITE_API_URL=http://127.0.0.1:8000/api

# Production / Docker — Postgres connection string
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Docker local (docker-compose.local.yml sets this automatically)
# DATABASE_URL=sqlite:////data/db.sqlite3

# Local dev without Clerk keys: backend accepts Bearer dev-user (DEBUG only).
