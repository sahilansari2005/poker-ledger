# Backend (Django)
SECRET_KEY=replace_me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Where users return after social login (Vite dev server or production app URL)
FRONTEND_URL=http://127.0.0.1:5173

# Comma-separated list. Include both localhost and 127.0.0.1 if you use either in the browser.
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional — only when the frontend cannot use the Vite proxy or same-origin /api
# VITE_API_URL=http://127.0.0.1:8000/api

# Production / Docker — Postgres connection string
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Redis — API response cache (optional)
# REDIS_URL=redis://127.0.0.1:6379/0
# CACHE_TTL=300
